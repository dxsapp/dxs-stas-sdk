{
  "name": "dxs-stas-sdk",
  "version": "2.1.0",
  "description": "TypeScript SDK for building and validating multiple Bitcoin SV transaction flows, including DSTAS token issue, transfer, split, merge, swap, freeze/unfreeze, and redeem.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxsapp/dxs-stas-sdk"
  },
  "scripts": {
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "tsc",
    "prepack": "npm run build",
    "check": "npm run check:nobuffer",
    "check:nobuffer": "node scripts/check-no-buffer.mjs",
    "lint": "eslint .",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "prepare": "node scripts/prepare-husky.mjs",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "start": "tsnd ./src/index.ts",
    "rollup": "rollup -c rollup.config.ts -w --configPlugin typescript"
  },
  "directories": {
    "test": "tests"
  },
  "author": "oleg@dxs.app (https://github.com/panagushin)",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.{js,json,md,yml,yaml,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bsv": {
      "types": "./dist/bsv.d.ts",
      "import": "./dist/bsv.js",
      "require": "./dist/bsv.js",
      "default": "./dist/bsv.js"
    },
    "./dstas": {
      "types": "./dist/dstas.d.ts",
      "import": "./dist/dstas.js",
      "require": "./dist/dstas.js",
      "default": "./dist/dstas.js"
    },
    "./stas": {
      "types": "./dist/stas.d.ts",
      "import": "./dist/stas.js",
      "require": "./dist/stas.js",
      "default": "./dist/stas.js"
    },
    "./package.json": "./package.json"
  }
}
